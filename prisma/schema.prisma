generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BlockType {
  HERO
  ABOUT
  EXPERIENCE
  CONTACT
}

model ContentBlock {
  id        String   @id @default(cuid())
  slug      String   @unique
  type      BlockType
  title     String
  subtitle  String?
  content   Json
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String
  imageUrl    String?
  githubUrl   String?
  liveUrl     String?
  technologies Json
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupportedSystem {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logoUrl          String
  shortDescription String
  experience       String
  projectLinks     Json
  certificateLinks Json
  resourceLinks    Json
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Certificate {
  id         String   @id @default(cuid())
  title      String
  issuer     String
  fileUrl    String
  externalUrl String?
  issuedAt   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ChatSession {
  id        String        @id @default(cuid())
  visitorId String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
